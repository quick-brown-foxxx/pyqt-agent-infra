#!/usr/bin/env bash
# Takes a screenshot inside the VM and copies it to the host.
# Agents call this script for visual feedback.
#
# Usage:
#   ./scripts/screenshot.sh [output_path]
#   ./scripts/screenshot.sh ./debug/after_click.png

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
SSH_CONFIG="$PROJECT_ROOT/.vagrant-ssh-config"

OUTPUT="${1:-/tmp/vm-screenshot.png}"
mkdir -p "$(dirname "$OUTPUT")"

REMOTE_PATH="/tmp/vm-screenshot-$$.png"

# Take screenshot inside VM
ssh -F "$SSH_CONFIG" \
    -o ControlMaster=auto \
    -o ControlPath="/tmp/vagrant-qt-dev-%r@%h:%p" \
    -o ControlPersist=10m \
    default \
    "DISPLAY={{ display }} scrot '$REMOTE_PATH'"

# Copy to host
scp -F "$SSH_CONFIG" \
    "default:$REMOTE_PATH" \
    "$OUTPUT"

# Clean up remote
ssh -F "$SSH_CONFIG" \
    -o ControlPath="/tmp/vagrant-qt-dev-%r@%h:%p" \
    default \
    "rm -f '$REMOTE_PATH'"

echo "Screenshot: $OUTPUT ($(du -h "$OUTPUT" | cut -f1))"
